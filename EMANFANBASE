<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Eman Fanbase – Find Me Here</title>
  <meta name="description" content="All links for Eman Fanbase – Telegram, Instagram, Pinterest & more."/>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=Raleway:wght@300;400;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #f5c842;
      --gold2: #e0a020;
      --dark: #0a0a0f;
      --card: rgba(255,255,255,0.04);
      --border: rgba(245,200,66,0.18);
      --text: #f0e8d0;
      --muted: #a09070;
    }

    body {
      min-height: 100vh;
      background: var(--dark);
      font-family: 'Raleway', sans-serif;
      color: var(--text);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
    }

    /* Animated starfield background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 40%, rgba(245,200,66,0.07) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 10%, rgba(100,60,200,0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 60% 90%, rgba(245,200,66,0.05) 0%, transparent 50%);
      z-index: 0;
      pointer-events: none;
    }

    .stars {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .star {
      position: absolute;
      border-radius: 50%;
      background: white;
      animation: twinkle var(--d, 3s) ease-in-out infinite var(--delay, 0s);
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.1; transform: scale(1); }
      50% { opacity: 0.8; transform: scale(1.4); }
    }

    .container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 480px;
      padding: 40px 20px 60px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* Avatar */
    .avatar-wrap {
      position: relative;
      margin-bottom: 24px;
      animation: floatAvatar 4s ease-in-out infinite;
    }
    @keyframes floatAvatar {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }
    .avatar-ring {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: conic-gradient(var(--gold), var(--gold2), #fff8, var(--gold));
      display: flex;
      align-items: center;
      justify-content: center;
      animation: spinRing 6s linear infinite;
      box-shadow: 0 0 40px rgba(245,200,66,0.3), 0 0 80px rgba(245,200,66,0.1);
    }
    @keyframes spinRing {
      to { transform: rotate(360deg); }
    }
    .avatar-inner {
      width: 98px;
      height: 98px;
      border-radius: 50%;
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 38px;
      border: 2px solid var(--dark);
    }

    /* Title */
    .title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(1.3rem, 5vw, 1.7rem);
      color: var(--gold);
      text-align: center;
      letter-spacing: 0.04em;
      text-shadow: 0 0 30px rgba(245,200,66,0.4);
      margin-bottom: 6px;
      animation: fadeDown 0.8s ease both;
    }
    .subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 36px;
      animation: fadeDown 0.9s ease both;
    }
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Section label */
    .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--muted);
      align-self: flex-start;
      padding-left: 4px;
      margin-bottom: 10px;
      margin-top: 28px;
    }
    .section-label:first-of-type { margin-top: 0; }

    /* Links */
    .links {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .link-card {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      border-radius: 16px;
      background: var(--card);
      border: 1px solid var(--border);
      text-decoration: none;
      color: var(--text);
      position: relative;
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      backdrop-filter: blur(10px);
      animation: cardIn 0.6s ease both;
    }
    .link-card:nth-child(1) { animation-delay: 0.1s; }
    .link-card:nth-child(2) { animation-delay: 0.2s; }
    .link-card:nth-child(3) { animation-delay: 0.3s; }
    .link-card:nth-child(4) { animation-delay: 0.4s; }
    .link-card:nth-child(5) { animation-delay: 0.5s; }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(24px) scale(0.97); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .link-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.04) 50%, transparent 70%);
      transform: translateX(-100%);
      transition: transform 0.5s ease;
    }
    .link-card:hover::before { transform: translateX(100%); }
    .link-card:hover {
      transform: translateY(-3px) scale(1.02);
      border-color: rgba(245,200,66,0.5);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 20px rgba(245,200,66,0.1);
    }
    .link-card:active { transform: scale(0.98); }

    /* Highlighted card */
    .link-card.featured {
      background: linear-gradient(135deg, rgba(245,200,66,0.12), rgba(224,160,32,0.06));
      border-color: rgba(245,200,66,0.4);
      box-shadow: 0 4px 24px rgba(245,200,66,0.08);
    }
    .link-card.featured:hover {
      box-shadow: 0 8px 40px rgba(245,200,66,0.2);
    }

    .link-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
      position: relative;
    }

    .link-info { flex: 1; min-width: 0; }
    .link-name {
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .link-desc {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .link-arrow {
      font-size: 1rem;
      opacity: 0.4;
      transition: opacity 0.2s, transform 0.2s;
      flex-shrink: 0;
    }
    .link-card:hover .link-arrow { opacity: 1; transform: translateX(4px); }

    /* Icon backgrounds */
    .icon-tg   { background: linear-gradient(135deg, #0088cc, #0055aa); }
    .icon-tgbot{ background: linear-gradient(135deg, #00aacc, #0077bb); }
    .icon-ig   { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
    .icon-pin  { background: linear-gradient(135deg, #bd081c, #8c0615); }
    .icon-plus { background: linear-gradient(135deg, #2a2a3a, #1a1a2a); border: 1px dashed rgba(245,200,66,0.3); }

    /* Badge */
    .badge {
      position: absolute;
      top: -4px;
      right: -4px;
      background: var(--gold);
      color: #000;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 2px 6px;
      border-radius: 20px;
      text-transform: uppercase;
    }

    /* Divider */
    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
      margin: 8px 0;
    }

    /* Footer */
    .footer {
      margin-top: 44px;
      font-size: 0.7rem;
      color: rgba(160,144,112,0.4);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
  </style>
</head>
